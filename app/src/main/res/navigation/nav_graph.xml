<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.gethandy.SplashFragment"
        android:label="Splash Screen"
        tools:layout="@layout/fragment_splash">

        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"/>

        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.gethandy.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"/>

        <action
            android:id="@+id/action_login_to_signup"
            app:destination="@id/signUpFragment"/>
    </fragment>

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.example.gethandy.SignUpFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_sign_up">

        <action
            android:id="@+id/action_signup_to_home"
            app:destination="@id/homeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.gethandy.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_login"
            app:destination="@id/loginFragment"/>

        <action
            android:id="@+id/action_home_to_search"
            app:destination="@id/searchFragment"/>

        <action
            android:id="@+id/action_home_to_profile"
            app:destination="@id/profileFragment"/>

        <action
            android:id="@+id/action_home_to_appointments"
            app:destination="@id/appointmentsFragment"/>
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.gethandy.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search">

        <action
            android:id="@+id/action_search_to_profile"
            app:destination="@id/profileFragment"/>
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.gethandy.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">

        <action
            android:id="@+id/action_profile_to_appointment_booking"
            app:destination="@id/appointmentBookingFragment"/>

        <action
            android:id="@+id/action_profile_to_appointments"
            app:destination="@id/appointmentsFragment"/>
    </fragment>

    <fragment
        android:id="@+id/appointmentsFragment"
        android:name="com.example.gethandy.AppointmentsFragment"
        android:label="Appointments"
        tools:layout="@layout/fragment_appointments">

        <action
            android:id="@+id/action_appointments_to_profile"
            app:destination="@id/profileFragment">
            <argument
                android:name="userId"
                app:argType="string" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/appointmentBookingFragment"
        android:name="com.example.gethandy.AppointmentBookingFragment"
        android:label="Book Appointment"
        tools:layout="@layout/fragment_appointment_booking">

    <action
        android:id="@+id/action_booking_to_home"
        app:destination="@id/homeFragment"/>
    </fragment>
</navigation>
