<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/appointmentCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvAppointmentDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="January 1, 2025"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAppointmentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="10:00 AM"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvAppointmentWith"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="With John Doe"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvAppointmentBusiness"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Plumber Pro"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAppointmentAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Cancel Appointment"
            android:layout_marginTop="8dp"
            android:textColor="@color/white"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>